{
    "name": "hwkdo/seventhings-laravel",
    "type": "library",
    "description": "Client for Seventhings ",
    "homepage": "https://hwk-do.de",
    "keywords": ["seventhings", "hwkdo"],
    "license": "MIT",
    "authors": [
        {
            "name": "Alexander Dieckmann",
            "homepage": "http://aleex.de"
        }
    ],
    "minimum-stability": "dev",
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "laravel/mcp": "^0.5"
    },
    
    "autoload": {        
